{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["app.main:app", "--host", "127.0.0.1", "--port", "8765", "--reload"],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": true,
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe",
            "envFile": "${workspaceFolder}/backend/.env"
        },
        {
            "name": "Build strony (build.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build.py",
            "args": ["--clean"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Aktualny plik (Python)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe"
        },
        {
            "name": "pytest — wszystkie testy",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["backend/tests", "-v"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe"
        }
    ],
    "compounds": [
        {
            "name": "Backend + Build (oba razem)",
            "configurations": ["Backend FastAPI (uvicorn)", "Build strony (build.py)"]
        }
    ]
}
